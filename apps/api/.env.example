# ===========================
# Application
# ===========================
# Runtime mode. One of: development | production | test
# Gates auth dev-mode short-circuit and Prisma logging verbosity.
NODE_ENV=development

# HTTP port the Express server binds to.
PORT=3000

# ===========================
# Database (PostgreSQL)
# ===========================
# PostgreSQL connection string used by Prisma.
# Defaults below align with the `postgres` service in docker-compose.yml.
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/flowspace

# ===========================
# Redis (Cache + Pub/Sub + BullMQ)
# ===========================
# Redis connection string used for WebSocket pub/sub and BullMQ job queues.
# Defaults below align with the `redis` service in docker-compose.yml.
REDIS_URL=redis://localhost:6379

# ===========================
# Clerk Authentication
# ===========================
# Get these from your Clerk dashboard: https://dashboard.clerk.com
# Use TEST keys (sk_test_* / pk_test_*) for local development.
# Never commit real LIVE keys (sk_live_* / pk_live_*) to version control.

# Clerk backend secret used to verify incoming JWTs on protected routes.
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here

# Clerk publishable key (for future frontend integration).
CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here

# Svix webhook secret used to verify POST /auth/webhook payloads from Clerk.
# Create a webhook endpoint in the Clerk dashboard and copy its signing secret.
CLERK_WEBHOOK_SECRET=whsec_your_webhook_secret_here
